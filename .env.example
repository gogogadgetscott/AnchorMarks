# ===============================================
# AnchorMarks Production Environment Configuration
# ===============================================

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Vite Dev Server Configuration
VITE_PORT=5173

# Security - CHANGE THESE IN PRODUCTION!
# App will refuse to start in production if this stays the placeholder
JWT_SECRET=your-super-secret-jwt-key-change-this-to-a-random-string

# Database (use absolute path like /data/anchormarks.db for production)
DB_PATH=./apps/database/anchormarks.db

# CORS (comma-separated list of allowed origins, or * for all; required in production)
CORS_ORIGIN=https://yourdomain.com

# Optional: API rate limiting (default 100 req/min per IP). If all traffic is one IP (e.g. Docker/proxy), raise or disable.
# RATE_LIMIT_MAX=500
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_DISABLED=0

# Optional: SSL/TLS (if running without reverse proxy)
SSL_ENABLED=false
# SSL_KEY=/path/to/privkey.pem
# SSL_CERT=/path/to/fullchain.pem

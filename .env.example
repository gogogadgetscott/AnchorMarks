# ===============================================
# AnchorMarks Production Environment Configuration
# ===============================================

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Vite Dev Server Configuration
VITE_PORT=5173

# Security - CHANGE THESE IN PRODUCTION!
# App will refuse to start in production if these stay as placeholders or match each other.
JWT_SECRET=your-super-secret-jwt-key-change-this-to-a-random-string
# Separate secret for refresh tokens — independent rotation without forcing a global logout.
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-to-a-different-random-string

# JWT expiry: access (short-lived) and refresh (long-lived; rotation on use). Defaults: 15m, 7d
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# Database (use absolute path like /data/anchormarks.db for production)
DB_PATH=./apps/database/anchormarks.db

# CORS (comma-separated list of allowed origins, or * for all; required in production)
CORS_ORIGIN=https://yourdomain.com

# Optional: API rate limiting. If all traffic is one IP (e.g. Docker/proxy), raise or disable.
# General API: 60 req/min per IP (tunable for normal usage).
# Auth (login/register): 10 req/min per IP (brute-force protection).
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_WINDOW_MS=60000
# RATE_LIMIT_DISABLED=0

# Optional: SSL/TLS (if running without reverse proxy)
SSL_ENABLED=false
# SSL_KEY=/path/to/privkey.pem
# SSL_CERT=/path/to/fullchain.pem

# Security audit log: file logging and retention (defaults: file off, 90 days retention; daily rotation)
# SECURITY_LOG_FILE=true
# SECURITY_LOG_RETENTION_DAYS=90
